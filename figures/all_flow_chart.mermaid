flowchart TB
  %% --- Style Definitions for a Print-Friendly, Detailed View ---
  classDef system stroke:#333,stroke-width:2px,fill:#f9f9f9
  classDef python fill:#fff,stroke:#38761d,stroke-width:2px
  classDef cpp fill:#fff,stroke:#a61c00,stroke-width:2px,stroke-dasharray: 5 5
  classDef lua fill:#fff,stroke:#741b47,stroke-width:2px,stroke-dasharray: 2 2
  classDef engine fill:#e6e6e6,stroke:#000
  classDef rosmsg fill:#fff,stroke:#f1c232,stroke-width:2px
  classDef user stroke-width:2px,stroke-dasharray: 5 5
  classDef hidden height:0px;

  %% --- Main System Blocks ---
  subgraph ros[ROS 2 Environment]
    subgraph sim_node[Simulation Node]
      SimManager[Simulation Manager]:::python
      VehicleManager[Vehicle Manager]:::python
      SensorRegistry[Sensor Registry]:::python
      ControllerRegistry[Controller Registry]:::python
    end
    subgraph ctrl_node[Controller Node]
      HighLevelController[High-Level Controller]:::python
      HighLevelCompute[Compute Control]:::cpp
    end
    ROSMsgs[(ROS Messages)]:::rosmsg
  end

  subgraph bng[BeamNG.tech Environment]
    BeamNGPy[BeamNGpy Interface]:::python
    subgraph vehicle_lua[Vehicle Lua]
      ExtController[Low Level Controller]:::lua
      GTState[Ground Truth Module]:::lua
    end
    Physics[Physics Engine]:::engine
  end

  %% --- External Actor ---
  User(("User")):::user

  %% --- Interactions ---
  %% Control and Command Flow (Solid Lines)
  User -- "Configure & Launch" --- mid:::hidden
  mid --> sim_node & ctrl_node
  SimManager -- "Initialize" --> VehicleManager
  VehicleManager -- "Register Components" --> SensorRegistry
  VehicleManager -- "Register Components" --> ControllerRegistry
  HighLevelController -- "Compute Target" --> HighLevelCompute
  HighLevelCompute -- "Return Target" --> HighLevelController
  HighLevelController -- "UDP: Send Target" --> ExtController
  SimManager -- "Initialize" --> BeamNGPy
  BeamNGPy -- "Instantiation" --> vehicle_lua
  ExtController -- "Update" --> Physics

  %% Data Flow (Dashed Lines)
  ExtController -. "UDP: Send State" .-> HighLevelController
  Physics -. "Physics State" .-> GTState
  GTState -. "Raw Data" .-> SensorRegistry
  SensorRegistry -. "Publish" .-> ROSMsgs
%%   ROSMsgs -. "Sensor Data" .-> HighLevelController
