flowchart TD
  %%––– Node styles
  classDef userInput       fill:#e1f5fe
  classDef pythonNodes     fill:#e8f5e9
  classDef cNodes          fill:#fcc9c9
  classDef rosNodes        fill:#fff3e0
  classDef luaNodes        fill:#f3e5f5
  classDef beamngNodes     fill:#ffebee

  %%––– Main diagram
  User(("User")):::userInput

  subgraph ROSEnv["ROS Environment"]
    ControllerInterface["controller_interface.py"]:::pythonNodes
    direction TB
    subgraph SimComponents["Simulation Node"]
      direction TB
      SimManager["simulation_manager.py"]:::pythonNodes
      VehicleManager["manager.py"]:::pythonNodes
      SensorRegistry["SensorRegistry"]:::pythonNodes
      GtStateSensor["GtState.py"]:::pythonNodes
      LowLevelController["low_level_controller.py"]:::pythonNodes
      ControllerRegistry["ControllerRegistry"]:::pythonNodes
    end
    subgraph CtrlComponents["Controller Node"]
      direction TB
      HighLevelController["high_level_controller.py"]:::pythonNodes
      HighLevelCompute["controller_core.c"]:::cNodes
    end
    ROSMsgs["ROS Messages"]:::rosNodes
  end

  subgraph BeamNGEnv["BeamNG Environment"]
    direction TB
    BeamNGPy["BeamNGpy Interface"]:::pythonNodes
    subgraph LuaSystem["Game Engine (ge) Lua"]
      direction TB
      XlabCore["xlabCore.lua"]:::luaNodes
      SensorsLua["sensors.lua"]:::luaNodes
    end
    subgraph VehicleLua["Vehicle Lua"]
      direction TB
      GtStateModule["gtState.lua"]:::luaNodes
      extController["controller.lua"]:::luaNodes
      ctrlManager["controllerManager.lua"]:::luaNodes
      ctrlImpl["controllerDefault.lua"]:::luaNodes
    end
    BeamNGPhysics["BeamNG Physics Engine"]:::beamngNodes
  end

  %%––– Command flows (solid orange)
  User -->|Launch| ControllerInterface
  ControllerInterface -->|config & initialize| SimManager
  ControllerInterface -->|config & initialize| HighLevelController
  SimManager -->|control vehicle & scenario| BeamNGPy
  SimManager -->|setup| VehicleManager
  VehicleManager -->|register| ControllerRegistry
  VehicleManager -->|register| SensorRegistry
  ControllerRegistry -->|create| LowLevelController
  SensorRegistry -->|create| GtStateSensor
  LowLevelController -->|open controller| BeamNGPy
  BeamNGPy -->|send commands| XlabCore
  XlabCore -->|setup| extController
  XlabCore -->|manage sensors| SensorsLua
  extController -->|register|ctrlManager
  ctrlManager -->|call|ctrlImpl
  HighLevelController <-->|UDP socket: send target & receive data| extController

  %%––– Internal compute
  HighLevelController <--> |compute target| HighLevelCompute

  %%––– Data flows (dashed blue)
  SensorsLua -->|sensor data| GtStateModule
  ctrlImpl <--> |update| BeamNGPhysics
  GtStateModule <-->|poll data| GtStateSensor & ctrlManager
  GtStateSensor -->|convert| ROSMsgs
